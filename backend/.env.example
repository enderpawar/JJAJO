# Google OAuth 2.0 (로그인용)
# 401 invalid_client 방지: 반드시 Google Cloud Console에서 발급한 값으로 설정하세요.
# 설정 방법: backend/GOOGLE_OAUTH_SETUP.md 참고
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 프론트엔드 URL (로그인 성공 후 리다이렉트, CORS 허용)
FRONTEND_ORIGIN=http://localhost:5173

# JWT 시크릿 (배포 시 필수, 32자 이상 권장. Safari 크로스 사이트 추적 방지 회피용)
# JWT_EXPIRATION_MS=604800000
JWT_SECRET=your-secret-at-least-32-chars-for-production
